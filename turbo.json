{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "FORSETY_API_KEY",
    "SHELBY_WALLET_ADDRESS",
    "SHELBY_MOCK",
    "NEXT_PUBLIC_APP_URL",
    "JWT_SECRET",
    "NEXT_PUBLIC_APTOS_NETWORK",
    "NEXT_PUBLIC_APTOS_API_KEY",
    "NODE_ENV",
    "MCP_PORT",
    "MCP_HOST",
    "MCP_CORS_ORIGIN",
    "FORSETY_HMAC_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "FORSETY_API_KEY",
        "SHELBY_WALLET_ADDRESS",
        "SHELBY_MOCK",
        "NEXT_PUBLIC_APP_URL",
        "JWT_SECRET",
        "NEXT_PUBLIC_APTOS_NETWORK",
        "NEXT_PUBLIC_APTOS_API_KEY",
        "NODE_ENV",
        "FORSETY_HMAC_SECRET"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    }
  }
}
