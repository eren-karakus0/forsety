# Shelby Protocol
SHELBY_RPC_URL=https://api.testnet.aptoslabs.com/v1
SHELBY_WALLET_ADDRESS=
SHELBY_CONTEXT=testnet

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon PostgreSQL)
# Required for: apps/web, packages/db (migrations), packages/mcp
# Migration: pnpm --filter @forsety/db db:migrate (new DBs)
#            pnpm --filter @forsety/db db:push (dev, applies schema directly)
DATABASE_URL=postgresql://user:password@host/forsety?sslmode=require

# Authentication (API Key)
FORSETY_API_KEY=your-api-key-here

# JWT Secret (min 32 chars, generate with: openssl rand -base64 48)
JWT_SECRET=

# HMAC Secret for share links (min 32 chars, generate with: openssl rand -base64 48)
FORSETY_HMAC_SECRET=

# Chain ID strictness for auth verification (Shelby Testnet, chain ID 2)
# Default: always strict
# Override: "false" = always lenient
# AUTH_STRICT_CHAIN_ID=

# Cookie domain for cross-subdomain auth (production only)
# Set to ".forsety.xyz" so forsety.xyz ↔ app.forsety.xyz share the auth cookie
# Leave empty/unset for localhost development
# COOKIE_DOMAIN=

# Aptos API Key (optional, for rate limit increase)
# NEXT_PUBLIC_APTOS_API_KEY=

# MCP Server (optional, for --transport=http mode)
MCP_PORT=3001
MCP_HOST=127.0.0.1
MCP_CORS_ORIGIN=*

# Shelby Mock Mode (set to "true" for local dev without devnet)
SHELBY_MOCK=true

# Sentry Error Tracking (optional, production only)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Analytics (optional, production only)
# Umami — cookieless, privacy-friendly page analytics
# NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js
# NEXT_PUBLIC_UMAMI_ID=
# Vercel Analytics & Speed Insights are auto-enabled via @vercel/analytics and @vercel/speed-insights
